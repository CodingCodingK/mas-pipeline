# Copy to .env and fill in values
# These override ${VAR} in config/settings.yaml

# LLM Provider API Keys (fill in at least one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Search
TAVILY_API_KEY=

