# Copy to .env and fill in values
# These override ${VAR} in config/settings.yaml

# LLM Provider API Keys (fill in at least one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Search
TAVILY_API_KEY=

# Database (defaults match docker-compose.yaml; no change needed for docker usage)
# POSTGRES_USER=mas
# POSTGRES_PASSWORD=mas_dev_2024
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5433
# POSTGRES_DB=mas_pipeline

# Redis (defaults match docker-compose.yaml; no change needed for docker usage)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Web frontend port (default: 80)
# WEB_PORT=80

# DB connection pool (SQLAlchemy). Keep pool_size + max_overflow ≤ PG max_connections - 10.
# DATABASE_POOL_SIZE=20
# DATABASE_MAX_OVERFLOW=40

# Monitoring stack (only used with `docker compose --profile monitoring up`)
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000
